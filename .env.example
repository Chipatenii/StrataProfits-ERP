# Supabase Configuration
NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# Optional: Development redirect URL for authentication
# NEXT_PUBLIC_DEV_SUPABASE_REDIRECT_URL=http://localhost:3000/dashboard

# Default Configuration
DEFAULT_ADMIN_PASSWORD=your_secure_password_here
NEXT_PUBLIC_DEFAULT_TAX_RATE=0
NEXT_PUBLIC_DEFAULT_DISCOUNT_RATE=0

# Resend Email Service
RESEND_API_KEY=re_your_resend_api_key
RESEND_FROM_EMAIL=StrataForge <noreply@yourdomain.com>
